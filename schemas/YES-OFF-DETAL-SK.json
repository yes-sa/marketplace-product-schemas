{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ArticleData Message Schema",
  "type": "object",
  "properties": {
    "sku": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": ["string", "null"] },
    "product_stock_category": { "type": "string" },
    "tax_rate": { "type": "number" },
    "unit_symbol": { "type": "string" },
    "unit_precision": { "type": ["integer", "null"] },

    "sales_channels": {
      "type": "array",
      "items": { "type": "string" }
    },

    "has_serial_number": { "type": "boolean" },

    "images": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "alt": { "type": ["string", "null"] },
          "default": { "type": "boolean" },
          "thumbnail": { "type": "boolean" },
          "title": { "type": ["string", "null"] },
          "type": { "type": ["string", "null"] },
          "unix_timestamp": { "type": ["integer", "null"] },
          "url": { "type": "string", "format": "uri" }
        },
        "required": ["url"],
        "additionalProperties": true
      }
    },
    "stones": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "stone": { "type": ["string", "null"] },
          "color": { "type": ["string", "null"] },
          "class": { "type": ["string", "null"] },
          "weight": { "type": ["string", "number", "null"] },
          "type": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "required": [
    "sku",
    "name",
    "product_stock_category",
    "tax_rate",
    "unit_symbol",
    "sales_channels",
    "unit_precision",
    "has_serial_number"
  ],
  "not": {
    "required": ["ore"]
  },
  "additionalProperties": true
}
